<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexPresenter.ViewModels"
             xmlns:models="using:NexPresenter.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="NexPresenter.Views.PresentationView"
             x:DataType="vm:PresentationViewModel">

    <Design.DataContext>
        <vm:PresentationViewModel/>
    </Design.DataContext>

    <Grid>
        <!-- Slides View (Default) -->
        <ScrollViewer IsVisible="{Binding ShowSlides}">
            <ItemsControl ItemsSource="{Binding AllSlides}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:Slide">
                        <Border Background="{DynamicResource SystemChromeMediumColor}" 
                                CornerRadius="8" 
                                Padding="16" 
                                Margin="12" 
                                Width="300" 
                                Height="200"
                                BoxShadow="0 2 8 rgba(0,0,0,0.1)">
                            <TextBlock Text="{Binding Content}" 
                                      TextWrapping="Wrap" 
                                      FontSize="16" 
                                      TextAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Details View -->
        <ScrollViewer IsVisible="{Binding ShowDetails}">
            <Border Padding="32">
                <StackPanel Spacing="24">
                    <!-- Name -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Presentation Name" FontWeight="SemiBold" FontSize="14"/>
                        <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter presentation name..." FontSize="16" Padding="12"/>
                    </StackPanel>

                    <!-- Description -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Description" FontWeight="SemiBold" FontSize="14"/>
                        <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 PlaceholderText="Enter a description..." 
                                 FontSize="14" 
                                 Padding="12"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="120"/>
                    </StackPanel>

                    <!-- Metadata -->
                    <Border Background="{DynamicResource SystemChromeMediumColor}" 
                            CornerRadius="8" 
                            Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Information" FontWeight="SemiBold" FontSize="16"/>
                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Created:" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CreatedAt, StringFormat='{}{0:MMMM dd, yyyy at HH:mm}'}"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Last Modified:" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ModifiedAt, StringFormat='{}{0:MMMM dd, yyyy at HH:mm}'}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
